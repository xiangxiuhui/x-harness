# Copy to .env (gitignored) and fill in. Installer auto-copies this on first install.

# ── DeepSeek (current default provider) ─────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ── ADR-0013: cheap auxiliary model for compaction / classification ─────────
# When set, x_harness routes summarization (long-conversation compaction) to
# this model instead of DEEPSEEK_MODEL. Recommended pairing:
#   DEEPSEEK_MODEL=deepseek-reasoner       # expensive main brain
#   DEEPSEEK_AUX_MODEL=deepseek-chat       # cheap summarizer
# Leave commented to let summarization fall back to DEEPSEEK_MODEL.
# DEEPSEEK_AUX_MODEL=deepseek-chat
