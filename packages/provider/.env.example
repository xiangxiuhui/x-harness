# Copy to .env (the repo root or current shell) and fill in.
# .env files are gitignored.

DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# ADR-0013 F1 — cheap auxiliary model for compaction / classification.
# When set, x_harness routes summarization to this model instead of DEEPSEEK_MODEL.
# DEEPSEEK_AUX_MODEL=deepseek-chat
